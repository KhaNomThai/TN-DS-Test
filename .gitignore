Thumbs.db

# Project-specific ignored files
# Heavy serialized binary models can be tracked as requested by the user
# model_output/models/*.joblib
# model_output/models/*.pkl

# MLflow tracking data (can be large, regenerated per environment)
mlruns/
mlruns.db

# Keep output directories in git
!model_output/models/.gitkeep
!model_output/tables/.gitkeep
!model_output/plots/.gitkeep
!mock_data/.gitkeep
